        <template id="hl_page_homepage" name="Hosting Local — Startpagina">
            <t t-call="website.layout">
                <t t-set="head">
                    <title>Hosting Local — Digitale onafhankelijkheid voor uw bedrijf</title>
                    <meta name="description"
                          content="Hosting Local levert energiezuinige servers, veilige cloudopslag en lokale AI-verwerking. Uw data blijft op uw eigen locatie."/>
                </t>

                <!-- ── HERO ── -->
                <section class="hl-hero">
                    <div class="container">
                        <span class="hl-hero-badge">Circulaire hardware · Lokale AI · Data-eigenaarschap</span>
                        <h1>Digitale onafhankelijkheid<br/><span>begint hier.</span></h1>
                        <p>
                            Uw server, uw data, uw regels. Hosting Local levert energiezuinige
                            thuisservers en beheerdiensten waarmee u volledig onafhankelijk bent
                            van grote cloudproviders — voor minder dan een Netflix-abonnement per maand.
                        </p>
                        <div class="hl-hero-btns">
                            <a href="/diensten" class="hl-btn-primary">Bekijk ons aanbod</a>
                            <a href="/contact" class="hl-btn-outline"
                               style="color:#fff;border-color:rgba(255,255,255,.5);">
                                Gratis adviesgesprek
                            </a>
                        </div>
                    </div>
                </section>

                <!-- ── USP strip ── -->
                <div class="hl-usp-strip">
                    <div class="container">
                        <div class="hl-usp-grid">
                            <div>
                                <span class="hl-usp-icon">🔒</span>
                                <h4>100% lokale data</h4>
                                <p>Niets gaat naar externe servers. Uw bestanden en AI-verwerking blijven in uw gebouw.</p>
                            </div>
                            <div>
                                <span class="hl-usp-icon">⚡</span>
                                <h4>Energiezuinig</h4>
                                <p>Onze refurbished servers verbruiken 35–65W — minder dan een gloeilamp, dag en nacht.</p>
                            </div>
                            <div>
                                <span class="hl-usp-icon">♻️</span>
                                <h4>Circulaire hardware</h4>
                                <p>Refurbished Dell OptiPlex en Lenovo P-serie via PV-consulting. Duurzaam en betaalbaar.</p>
                            </div>
                            <div>
                                <span class="hl-usp-icon">🤝</span>
                                <h4>Persoonlijke service</h4>
                                <p>Geen callcenter. Eén aanspreekpunt dat uw infrastructuur door en door kent.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── DIENSTEN GRID ── -->
                <section class="hl-section hl-section-alt">
                    <div class="container">
                        <span class="hl-label">Wat wij doen</span>
                        <h2 class="hl-title">Alles wat uw digitale onafhankelijkheid nodig heeft</h2>
                        <p class="hl-subtitle">
                            Van uw eerste server tot een volledig beheerd IT-platform — wij begeleiden
                            elk traject van a tot z.
                        </p>
                        <div class="hl-diensten-grid">
                            <a href="/diensten#servers" class="hl-dienst-card">
                                <span class="hl-dienst-icon">🖥️</span>
                                <h3>Thuisserver &amp; Opslag</h3>
                                <p>Eigen server voor bestanden, back-ups en applicaties. Zuinig, stil en betrouwbaar.</p>
                            </a>
                            <a href="/diensten#backup" class="hl-dienst-card">
                                <span class="hl-dienst-icon">💾</span>
                                <h3>Back-up &amp; Herstel</h3>
                                <p>Automatische nachtelijke back-ups met gegarandeerd herstel. Nooit meer data kwijt.</p>
                            </a>
                            <a href="/diensten#ai" class="hl-dienst-card">
                                <span class="hl-dienst-icon">🤖</span>
                                <h3>Lokale AI</h3>
                                <p>ChatGPT-achtige assistent die draait op uw eigen server. Uw prompts verlaten uw netwerk nooit.</p>
                            </a>
                            <a href="/diensten#monitoring" class="hl-dienst-card">
                                <span class="hl-dienst-icon">📊</span>
                                <h3>Monitoring &amp; Beheer</h3>
                                <p>Wij houden uw infrastructuur in de gaten en grijpen in voordat u iets merkt.</p>
                            </a>
                            <a href="/diensten#beveiliging" class="hl-dienst-card">
                                <span class="hl-dienst-icon">🛡️</span>
                                <h3>Beveiliging</h3>
                                <p>VPN, firewall en toegangsbeheer zodat alleen de juiste mensen bij uw data kunnen.</p>
                            </a>
                            <a href="/diensten#m365" class="hl-dienst-card">
                                <span class="hl-dienst-icon">📧</span>
                                <h3>Microsoft 365</h3>
                                <p>Implementatie en beheer van Teams, e-mail en OneDrive voor uw hele organisatie.</p>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- ── VOOR WIE ── -->
                <section class="hl-section">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <span class="hl-label">Voor wie</span>
                                <h2 class="hl-title">Gemaakt voor kleine ondernemingen en<br/>ambitieuze particulieren</h2>
                                <p style="font-size:16px;color:#4B5563;line-height:1.7;margin-bottom:24px;">
                                    U bent advocaat, architect, coworkinguitbater of zelfstandige met gevoelige
                                    klantgegevens. U wilt controle over uw data zonder het budget of de kennis
                                    van een IT-afdeling.
                                </p>
                                <ul style="list-style:none;padding:0;margin:0 0 28px;">
                                    <li style="padding:8px 0;border-bottom:1px solid #f0f0f0;color:#1A2E5A;">
                                        ✅ <strong>Vrije beroepen</strong> met vertrouwelijke klantdossiers
                                    </li>
                                    <li style="padding:8px 0;border-bottom:1px solid #f0f0f0;color:#1A2E5A;">
                                        ✅ <strong>Coworkingruimtes</strong> die een professioneel IT-pakket willen
                                    </li>
                                    <li style="padding:8px 0;border-bottom:1px solid #f0f0f0;color:#1A2E5A;">
                                        ✅ <strong>KMO's</strong> die willen stoppen met Google/Dropbox
                                    </li>
                                    <li style="padding:8px 0;color:#1A2E5A;">
                                        ✅ <strong>Particulieren</strong> met een home-lab of smart home
                                    </li>
                                </ul>
                                <a href="/contact" class="hl-btn-primary">Bespreek uw situatie</a>
                            </div>
                            <div class="col-md-6 d-none d-md-block text-center" style="padding-left:48px;">
                                <!-- Illustratie: server in kantoor -->
                                <svg viewBox="0 0 280 220" xmlns="http://www.w3.org/2000/svg"
                                     style="max-width:280px;width:100%;">
                                    <rect x="40" y="30" width="200" height="160" rx="6"
                                          fill="#F9FAFB" stroke="#e5e7eb" stroke-width="1.5"/>
                                    <!-- server racks -->
                                    <rect x="70" y="55" width="140" height="28" rx="4"
                                          fill="#1A2E5A"/>
                                    <rect x="78" y="61" width="12" height="16" rx="2"
                                          fill="#F5B800"/>
                                    <rect x="96" y="65" width="24" height="5" rx="2.5"
                                          fill="rgba(255,255,255,.3)"/>
                                    <rect x="126" y="65" width="16" height="5" rx="2.5"
                                          fill="rgba(255,255,255,.3)"/>
                                    <circle cx="192" cy="69" r="4" fill="#22c55e"/>
                                    <rect x="70" y="91" width="140" height="28" rx="4"
                                          fill="#1A2E5A"/>
                                    <rect x="78" y="97" width="12" height="16" rx="2"
                                          fill="#F5B800"/>
                                    <rect x="96" y="101" width="24" height="5" rx="2.5"
                                          fill="rgba(255,255,255,.3)"/>
                                    <rect x="126" y="101" width="16" height="5" rx="2.5"
                                          fill="rgba(255,255,255,.3)"/>
                                    <circle cx="192" cy="105" r="4" fill="#22c55e"/>
                                    <rect x="70" y="127" width="140" height="28" rx="4"
                                          fill="#1A2E5A"/>
                                    <rect x="78" y="133" width="12" height="16" rx="2"
                                          fill="#F5B800"/>
                                    <rect x="96" y="137" width="24" height="5" rx="2.5"
                                          fill="rgba(255,255,255,.3)"/>
                                    <rect x="126" y="137" width="16" height="5" rx="2.5"
                                          fill="rgba(255,255,255,.3)"/>
                                    <circle cx="192" cy="141" r="4" fill="#22c55e"/>
                                    <!-- label -->
                                    <text x="140" y="185" text-anchor="middle"
                                          font-family="'Inter',sans-serif" font-size="11"
                                          fill="#9CA3AF">Uw server · uw locatie</text>
                                </svg>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ── CTA BAND ── -->
                <div class="hl-cta-band text-center">
                    <div class="container">
                        <h2>Klaar om uw data terug in eigen handen te nemen?</h2>
                        <p>Geen technische kennis vereist. Wij installeren, configureren en beheren alles voor u.</p>
                        <a href="/contact" class="hl-btn-dark">Gratis adviesgesprek aanvragen</a>
                    </div>
                </div>

            </t>
        </template>

