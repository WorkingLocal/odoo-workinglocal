        <template id="hl_page_contact" name="Hosting Local — Contact">
            <t t-call="website.layout">
                <t t-set="head">
                    <title>Contact — Hosting Local</title>
                    <meta name="description"
                          content="Neem contact op met Hosting Local voor een vrijblijvend adviesgesprek."/>
                </t>

                <section class="hl-hero" style="padding:56px 0 48px;">
                    <div class="container">
                        <span class="hl-hero-badge">Vrijblijvend advies</span>
                        <h1 style="font-size:clamp(28px,4vw,44px);">Laten we praten</h1>
                        <p>Stel uw vraag of vraag een gratis adviesgesprek aan. We antwoorden binnen 1 werkdag.</p>
                    </div>
                </section>

                <section class="hl-section">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-7">
                                <t t-if="request.params.get('error')">
                                    <div style="background:#fef2f2;border:1px solid #fca5a5;padding:14px 18px;margin-bottom:20px;color:#991b1b;font-size:14px;">
                                        Gelieve uw naam en e-mailadres in te vullen.
                                    </div>
                                </t>
                                <form action="/hostinglocal/contact/submit" method="post"
                                      class="hl-contact-form">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <div class="row">
                                        <div class="col-md-6 hl-form-group">
                                            <label for="naam">Naam *</label>
                                            <input type="text" id="naam" name="naam"
                                                   placeholder="Jan Janssen" required="required"/>
                                        </div>
                                        <div class="col-md-6 hl-form-group">
                                            <label for="bedrijf">Bedrijf</label>
                                            <input type="text" id="bedrijf" name="bedrijf"
                                                   placeholder="Uw bedrijfsnaam (optioneel)"/>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6 hl-form-group">
                                            <label for="email">E-mailadres *</label>
                                            <input type="email" id="email" name="email"
                                                   placeholder="jan@bedrijf.be" required="required"/>
                                        </div>
                                        <div class="col-md-6 hl-form-group">
                                            <label for="telefoon">Telefoonnummer</label>
                                            <input type="tel" id="telefoon" name="telefoon"
                                                   placeholder="+32 xxx xx xx xx"/>
                                        </div>
                                    </div>
                                    <div class="hl-form-group">
                                        <label for="interesse">Waarmee kan ik u helpen?</label>
                                        <select id="interesse" name="interesse">
                                            <option value="">-- Kies een onderwerp --</option>
                                            <option value="server">Thuisserver of opslag</option>
                                            <option value="backup">Back-up &amp; Herstel</option>
                                            <option value="ai">Lokale AI-verwerking</option>
                                            <option value="monitoring">Monitoring &amp; Beheer</option>
                                            <option value="beveiliging">Beveiliging &amp; VPN</option>
                                            <option value="m365">Microsoft 365</option>
                                            <option value="anders">Iets anders</option>
                                        </select>
                                    </div>
                                    <div class="hl-form-group">
                                        <label for="bericht">Uw bericht</label>
                                        <textarea id="bericht" name="bericht"
                                                  placeholder="Vertel ons kort over uw situatie..."></textarea>
                                    </div>
                                    <button type="submit" class="hl-btn-primary"
                                            style="border:none;cursor:pointer;width:100%;">
                                        Verstuur aanvraag
                                    </button>
                                </form>
                            </div>
                            <div class="col-md-5 d-none d-md-block" style="padding-left:48px;">
                                <div style="position:sticky;top:100px;">
                                    <h3 style="font-size:20px;font-weight:700;color:#1A2E5A;margin-bottom:20px;">
                                        Wat kunt u verwachten?
                                    </h3>
                                    <div style="display:flex;flex-direction:column;gap:20px;">
                                        <div style="display:flex;gap:14px;align-items:flex-start;">
                                            <div style="width:36px;height:36px;background:#F5B800;border:2px solid #1A2E5A;display:flex;align-items:center;justify-content:center;font-weight:800;color:#1A2E5A;flex-shrink:0;">1</div>
                                            <div>
                                                <div style="font-weight:700;color:#1A2E5A;margin-bottom:4px;">Reactie binnen 1 werkdag</div>
                                                <div style="font-size:14px;color:#6B7280;">We lezen elke aanvraag persoonlijk en sturen een gerichte reactie.</div>
                                            </div>
                                        </div>
                                        <div style="display:flex;gap:14px;align-items:flex-start;">
                                            <div style="width:36px;height:36px;background:#F5B800;border:2px solid #1A2E5A;display:flex;align-items:center;justify-content:center;font-weight:800;color:#1A2E5A;flex-shrink:0;">2</div>
                                            <div>
                                                <div style="font-weight:700;color:#1A2E5A;margin-bottom:4px;">Gratis adviesgesprek</div>
                                                <div style="font-size:14px;color:#6B7280;">30 minuten video of telefoon om uw situatie te bespreken. Zonder verplichtingen.</div>
                                            </div>
                                        </div>
                                        <div style="display:flex;gap:14px;align-items:flex-start;">
                                            <div style="width:36px;height:36px;background:#F5B800;border:2px solid #1A2E5A;display:flex;align-items:center;justify-content:center;font-weight:800;color:#1A2E5A;flex-shrink:0;">3</div>
                                            <div>
                                                <div style="font-weight:700;color:#1A2E5A;margin-bottom:4px;">Concreet voorstel</div>
                                                <div style="font-size:14px;color:#6B7280;">Op maat gemaakt aanbod met duidelijke prijs, tijdlijn en wat u kunt verwachten.</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="margin-top:32px;padding:20px;background:#F9FAFB;border:1px solid #e5e7eb;">
                                        <div style="font-size:13px;font-weight:700;color:#1A2E5A;margin-bottom:6px;">
                                            📧 Direct bereikbaar
                                        </div>
                                        <div style="font-size:14px;color:#6B7280;">
                                            <a href="mailto:info@hostinglocal.be"
                                               style="color:#1A2E5A;font-weight:600;">info@hostinglocal.be</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

