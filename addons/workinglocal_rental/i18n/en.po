#: model:mail.template,body_html:workinglocal_rental.mail_template_rental_contract_activated
msgid ""
"<div style=\"margin: 0; padding: 0;\">\n"
"                <p>Beste {{ object.partner_id.name }},</p>\n"
"                <p>\n"
"                    Je huurcontract <strong>{{ object.name }}</strong> is nu actief, met start op\n"
"                    <t t-out=\"format_date(object.date_start)\"/>.\n"
"                </p>\n"
"                <p>\n"
"                    Facturatie gebeurt automatisch, elke maand rond de <t t-out=\"object.invoice_day\"/>e.\n"
"                </p>\n"
"                <p>\n"
"                    Wil je zelf extra ruimtes reserveren (bv. de concertzaal of vergaderruimte)?\n"
"                    Dat kan via het klantenportaal, zodra je daar toegang toe hebt gekregen.\n"
"                </p>\n"
"                <p>Met vriendelijke groeten,<br/>Working Local</p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0; padding: 0;\">\n"
"                <p>Dear {{ object.partner_id.name }},</p>\n"
"                <p>\n"
"                    Your rental contract <strong>{{ object.name }}</strong> is now active, starting on\n"
"                    <t t-out=\"format_date(object.date_start)\"/>.\n"
"                </p>\n"
"                <p>\n"
"                    Billing happens automatically, every month around the <t t-out=\"object.invoice_day\"/>th.\n"
"                </p>\n"
"                <p>\n"
"                    Want to book extra spaces yourself (e.g. the concert hall or meeting room)?\n"
"                    That is possible via the customer portal, once you have been given access to it.\n"
"                </p>\n"
"                <p>Kind regards,<br/>Working Local</p>\n"
"            </div>\n"
"        "

#: model_terms:ir.ui.view,arch_db:workinglocal_rental.website_floorplan
msgid ""
"<span><span class=\"floorplan-dot\" style=\"background:#9CA8C4;\"/> Vrij</span>\n"
"                            <span><span class=\"floorplan-dot\" style=\"background:#2563EB;\"/> Gereserveerd vandaag</span>\n"
"                            <span><span class=\"floorplan-dot\" style=\"background:#F5B800;\"/> Bezet nu</span>\n"
"                            <span><span class=\"floorplan-dot\" style=\"background:#16A34A;\"/> Verhuurd</span>"
msgstr ""
"<span><span class=\"floorplan-dot\" style=\"background:#9CA8C4;\"/> Free</span>\n"
"                            <span><span class=\"floorplan-dot\" style=\"background:#2563EB;\"/> Reserved today</span>\n"
"                            <span><span class=\"floorplan-dot\" style=\"background:#F5B800;\"/> Occupied now</span>\n"
"                            <span><span class=\"floorplan-dot\" style=\"background:#16A34A;\"/> Rented</span>"

