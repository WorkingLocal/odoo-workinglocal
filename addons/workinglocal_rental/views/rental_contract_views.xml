<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── LIST VIEW ─────────────────────────────────────────────────── -->
    <record id="view_rental_contract_list" model="ir.ui.view">
        <field name="name">rental.contract.list</field>
        <field name="model">rental.contract</field>
        <field name="arch" type="xml">
            <list string="Huurcontracten"
                  decoration-success="state == 'active'"
                  decoration-muted="state == 'ended'"
                  decoration-warning="state == 'draft'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_start"/>
                <field name="date_end" optional="show"/>
                <field name="total_monthly" widget="monetary"/>
                <field name="invoice_count" string="Facturen" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'draft'"
                       decoration-muted="state == 'ended'"/>
            </list>
        </field>
    </record>

    <!-- ── FORM VIEW ─────────────────────────────────────────────────── -->
    <record id="view_rental_contract_form" model="ir.ui.view">
        <field name="name">rental.contract.form</field>
        <field name="model">rental.contract</field>
        <field name="arch" type="xml">
            <form string="Huurcontract">
                <header>
                    <button name="action_activate" string="Activeren" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_generate_invoice" string="Factuur aanmaken" type="object"
                            class="btn-success"
                            invisible="state != 'active'"/>
                    <button name="action_end" string="Beëindigen" type="object"
                            invisible="state != 'active'"/>
                    <button name="action_reset_draft" string="Naar concept" type="object"
                            invisible="state != 'ended'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,ended"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_invoices" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Facturen"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Contract">
                            <field name="partner_id"/>
                            <field name="date_start"/>
                            <field name="date_end" placeholder="Open einde"/>
                            <field name="invoice_day"/>
                        </group>
                        <group string="Bedrag">
                            <field name="currency_id" invisible="1"/>
                            <field name="total_monthly" widget="monetary" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Huurregels"/>
                    <field name="line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="workspace_id" optional="show"/>
                            <field name="description" required="1"/>
                            <field name="qty"/>
                            <field name="price_month" widget="monetary"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>

                    <group class="oe_subtotal_footer">
                        <field name="total_monthly" widget="monetary"
                               string="Totaal / maand" readonly="1"
                               class="oe_subtotal_footer_separator"/>
                    </group>

                    <separator string="Opmerkingen"/>
                    <field name="note" placeholder="Interne opmerkingen, afspraken, bijzonderheden..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── SEARCH VIEW ───────────────────────────────────────────────── -->
    <record id="view_rental_contract_search" model="ir.ui.view">
        <field name="name">rental.contract.search</field>
        <field name="model">rental.contract</field>
        <field name="arch" type="xml">
            <search string="Huurcontracten zoeken">
                <field name="name"/>
                <field name="partner_id"/>
                <filter string="Actief" name="active" domain="[('state','=','active')]"/>
                <filter string="Concept" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Beëindigd" name="ended" domain="[('state','=','ended')]"/>
                <separator/>
                <filter string="Groepeer op huurder" name="group_partner"
                        context="{'group_by': 'partner_id'}"/>
                <filter string="Groepeer op status" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- ── ACTION ────────────────────────────────────────────────────── -->
    <record id="action_rental_contract" model="ir.actions.act_window">
        <field name="name">Huurcontracten</field>
        <field name="res_model">rental.contract</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_rental_contract_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
