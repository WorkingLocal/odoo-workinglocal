<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        E-mail notificatie layout — Working Local branding
        Knopkleur wordt gestuurd via company.email_secondary_color (geel) + email_primary_color (navy).
        Hier overschrijven we enkel de "Powered by Odoo" voettekst.
    -->
    <template id="mail_notification_layout_wl" inherit_id="mail.mail_notification_layout" name="Working Local - E-mail Layout">

        <!-- Vervang "Powered by Odoo" door "Working Local" -->
        <xpath expr="//a[@href='https://www.odoo.com?utm_source=db&amp;utm_medium=email']" position="replace">
            <a href="https://workinglocal.be" style="color: #F5B800; text-decoration: none; font-weight: 600;">Working Local</a>
        </xpath>

    </template>
</odoo>
