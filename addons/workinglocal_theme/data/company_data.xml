<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Stel Working Local bedrijfslogo in (wordt getoond op login-pagina en documenten) -->
    <record id="base.main_company" model="res.company">
        <field name="name">Working Local</field>
        <field name="logo" type="base64" file="workinglocal_theme/static/src/img/logo.png"/>
        <field name="favicon" type="base64" file="workinglocal_theme/static/src/img/logo.png"/>
        <!-- E-mail notificatie kleuren: gele knop met navy tekst -->
        <field name="email_secondary_color">#F5B800</field>
        <field name="email_primary_color">#1A2E5A</field>
    </record>
</odoo>
