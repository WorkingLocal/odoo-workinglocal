<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_unifi" model="ir.ui.view">
        <field name="name">project.project.form.unifi</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <!-- UniFi Design Center URL na het klantenveld -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="unifi_design_url" widget="url"
                       placeholder="https://design.ui.com/projects/..."/>
            </xpath>
        </field>
    </record>
</odoo>
