<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── LIST VIEW ─────────────────────────────────────────────────── -->
    <record id="view_coworking_package_list" model="ir.ui.view">
        <field name="name">coworking.package.list</field>
        <field name="model">coworking.package</field>
        <field name="arch" type="xml">
            <list string="Pakketten" decoration-muted="not active">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="workspace_ids" widget="many2many_tags"/>
                <field name="price"/>
                <field name="reservation_count" string="Reservaties"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── FORM VIEW ─────────────────────────────────────────────────── -->
    <record id="view_coworking_package_form" model="ir.ui.view">
        <field name="name">coworking.package.form</field>
        <field name="model">coworking.package</field>
        <field name="arch" type="xml">
            <form string="Pakket">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_coworking_reservation)s" type="action"
                                class="oe_stat_button" icon="fa-calendar">
                            <field name="reservation_count" widget="statinfo" string="Reservaties"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Naam pakket"/></h1>
                    </div>
                    <group>
                        <group string="Ruimten en prijs">
                            <field name="currency_id" invisible="1"/>
                            <field name="workspace_ids" widget="many2many_tags"/>
                            <field name="price"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Beschikbare dagen">
                            <field name="avail_mon"/>
                            <field name="avail_tue"/>
                            <field name="avail_wed"/>
                            <field name="avail_thu"/>
                            <field name="avail_fri"/>
                            <field name="avail_sat"/>
                            <field name="avail_sun"/>
                        </group>
                    </group>
                    <group string="Omschrijving">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Reservaties">
                            <field name="reservation_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="booking_type"/>
                                    <field name="slot" optional="show"/>
                                    <field name="start_datetime"/>
                                    <field name="end_datetime"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── SEARCH VIEW ───────────────────────────────────────────────── -->
    <record id="view_coworking_package_search" model="ir.ui.view">
        <field name="name">coworking.package.search</field>
        <field name="model">coworking.package</field>
        <field name="arch" type="xml">
            <search string="Pakketten zoeken">
                <field name="name"/>
                <field name="workspace_ids"/>
                <filter string="Actief" name="active" domain="[('active','=',True)]"/>
            </search>
        </field>
    </record>

    <!-- ── ACTION ────────────────────────────────────────────────────── -->
    <record id="action_coworking_package" model="ir.actions.act_window">
        <field name="name">Pakketten</field>
        <field name="res_model">coworking.package</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_coworking_package_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>


</odoo>
