<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── LIST VIEW ─────────────────────────────────────────────────── -->
    <record id="view_coworking_membership_list" model="ir.ui.view">
        <field name="name">coworking.membership.list</field>
        <field name="model">coworking.membership</field>
        <field name="arch" type="xml">
            <list string="Lidmaatschappen"
                  decoration-success="state == 'active'"
                  decoration-warning="state == 'trial'"
                  decoration-muted="state == 'expired'">
                <field name="partner_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'trial'"
                       decoration-danger="state == 'expired'"/>
                <field name="start_date"/>
                <field name="trial_end_date"/>
                <field name="is_in_trial"/>
                <field name="reservation_count" string="Reservaties"/>
            </list>
        </field>
    </record>

    <!-- ── FORM VIEW ─────────────────────────────────────────────────── -->
    <record id="view_coworking_membership_form" model="ir.ui.view">
        <field name="name">coworking.membership.form</field>
        <field name="model">coworking.membership</field>
        <field name="arch" type="xml">
            <form string="Lidmaatschap">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="trial,active,expired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_coworking_reservation)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-calendar"
                                context="{'default_partner_id': partner_id, 'search_default_partner_id': partner_id}">
                            <field name="reservation_count" widget="statinfo" string="Reservaties"/>
                        </button>
                    </div>
                    <group>
                        <group string="Lid">
                            <field name="partner_id"/>
                            <field name="state"/>
                            <field name="is_in_trial" readonly="1"/>
                        </group>
                        <group string="Proefperiode">
                            <field name="start_date"/>
                            <field name="trial_days"/>
                            <field name="trial_end_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reservaties">
                            <field name="reservation_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="workspace_id"/>
                                    <field name="start_datetime"/>
                                    <field name="end_datetime"/>
                                    <field name="billing_type"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── SEARCH VIEW ───────────────────────────────────────────────── -->
    <record id="view_coworking_membership_search" model="ir.ui.view">
        <field name="name">coworking.membership.search</field>
        <field name="model">coworking.membership</field>
        <field name="arch" type="xml">
            <search string="Lidmaatschappen zoeken">
                <field name="partner_id"/>
                <filter string="Proefperiode" name="trial" domain="[('state','=','trial')]"/>
                <filter string="Actief" name="active" domain="[('state','=','active')]"/>
                <filter string="Verlopen" name="expired" domain="[('state','=','expired')]"/>
            </search>
        </field>
    </record>

    <!-- ── ACTION ────────────────────────────────────────────────────── -->
    <record id="action_coworking_membership" model="ir.actions.act_window">
        <field name="name">Lidmaatschappen</field>
        <field name="res_model">coworking.membership</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_coworking_membership_search"/>
    </record>


</odoo>
