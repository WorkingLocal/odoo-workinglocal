#. module: coworking_reservation
#: model:mail.template,body_html:coworking_reservation.mail_template_reservation_confirmed
msgid ""
"<div style=\"margin: 0; padding: 0;\">\n"
"                <p>Beste {{ object.partner_id.name }},</p>\n"
"                <p>\n"
"                    Goed nieuws — je reservatie <strong>{{ object.name }}</strong> voor\n"
"                    <strong t-out=\"object.package_id.name or object.workspace_id.name\"/>\n"
"                    is bevestigd.\n"
"                </p>\n"
"                <p>\n"
"                    <t t-out=\"format_datetime(object.start_datetime, tz=object.partner_id.tz, dt_format='short')\"/>\n"
"                    tot\n"
"                    <t t-out=\"format_datetime(object.end_datetime, tz=object.partner_id.tz, dt_format='short')\"/>\n"
"                </p>\n"
"                <t t-if=\"object.invoice_id\">\n"
"                    <p>De factuur volgt binnenkort per e-mail.</p>\n"
"                </t>\n"
"                <p>Alle details vind je terug via je\n"
"                    <a t-attf-href=\"/mijn/reservaties/{{ object.id }}\">klantenportaal</a>.\n"
"                </p>\n"
"                <p>Met vriendelijke groeten,<br/>Working Local</p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0; padding: 0;\">\n"
"                <p>Dear {{ object.partner_id.name }},</p>\n"
"                <p>\n"
"                    Good news — your reservation <strong>{{ object.name }}</strong> for\n"
"                    <strong t-out=\"object.package_id.name or object.workspace_id.name\"/>\n"
"                    is confirmed.\n"
"                </p>\n"
"                <p>\n"
"                    <t t-out=\"format_datetime(object.start_datetime, tz=object.partner_id.tz, dt_format='short')\"/>\n"
"                    to\n"
"                    <t t-out=\"format_datetime(object.end_datetime, tz=object.partner_id.tz, dt_format='short')\"/>\n"
"                </p>\n"
"                <t t-if=\"object.invoice_id\">\n"
"                    <p>The invoice will follow shortly by e-mail.</p>\n"
"                </t>\n"
"                <p>You can find all details via your\n"
"                    <a t-attf-href=\"/mijn/reservaties/{{ object.id }}\">customer portal</a>.\n"
"                </p>\n"
"                <p>Kind regards,<br/>Working Local</p>\n"
"            </div>\n"
"        "

#. module: coworking_reservation
#: model:mail.template,body_html:coworking_reservation.mail_template_reservation_received
msgid ""
"<div style=\"margin: 0; padding: 0;\">\n"
"                <p>Beste {{ object.partner_id.name }},</p>\n"
"                <p>\n"
"                    We hebben je aanvraag <strong>{{ object.name }}</strong> voor\n"
"                    <strong t-out=\"object.package_id.name or object.workspace_id.name\"/>\n"
"                    ontvangen, van\n"
"                    <t t-out=\"format_datetime(object.start_datetime, tz=object.partner_id.tz, dt_format='short')\"/>\n"
"                    tot\n"
"                    <t t-out=\"format_datetime(object.end_datetime, tz=object.partner_id.tz, dt_format='short')\"/>.\n"
"                </p>\n"
"                <p>\n"
"                    Dit is nog geen bevestiging — we nemen je aanvraag zo snel mogelijk door\n"
"                    en laten je weten zodra de plek definitief voor jou gereserveerd is.\n"
"                </p>\n"
"                <p>Je kan de status van je aanvraag altijd opvolgen via je\n"
"                    <a t-attf-href=\"/mijn/reservaties/{{ object.id }}\">klantenportaal</a>.\n"
"                </p>\n"
"                <p>Met vriendelijke groeten,<br/>Working Local</p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0; padding: 0;\">\n"
"                <p>Dear {{ object.partner_id.name }},</p>\n"
"                <p>\n"
"                    We have received your request <strong>{{ object.name }}</strong> for\n"
"                    <strong t-out=\"object.package_id.name or object.workspace_id.name\"/>\n"
"                    , from\n"
"                    <t t-out=\"format_datetime(object.start_datetime, tz=object.partner_id.tz, dt_format='short')\"/>\n"
"                    to\n"
"                    <t t-out=\"format_datetime(object.end_datetime, tz=object.partner_id.tz, dt_format='short')\"/>.\n"
"                </p>\n"
"                <p>\n"
"                    This is not yet a confirmation — we will review your request as soon as\n"
"                    possible and let you know once the spot is definitively reserved for you.\n"
"                </p>\n"
"                <p>You can always follow the status of your request via your\n"
"                    <a t-attf-href=\"/mijn/reservaties/{{ object.id }}\">customer portal</a>.\n"
"                </p>\n"
"                <p>Kind regards,<br/>Working Local</p>\n"
"            </div>\n"
"        "

